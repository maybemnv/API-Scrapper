# Required
GROQ_API_KEY=gsk_your_key_here

# Optional — increases GitHub API rate limits
GITHUB_TOKEN=github_pat_your_token_here
# GH_TOKEN is an alias for GITHUB_TOKEN

# Optional — override AI policy path
# AI_POLICY_PATH=/custom/path/ai_policy.json

# Optional — persist healthy proxy list pruning
# X3D_UP_PROXY=1
